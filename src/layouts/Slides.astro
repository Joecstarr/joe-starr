---
import { type CollectionEntry } from "astro:content";
import RevealSlides from "~/components/slides/RevealSlides.astro";

interface Props {
    post: CollectionEntry<"slides">;
    color:
        | "black"
        | "white"
        | "league"
        | "beige"
        | "dracula"
        | "sky"
        | "night"
        | "serif"
        | "simple"
        | "solarized"
        | "blood"
        | "moon";
}

const { post, theme = "black" } = Astro.props;
const { title, description, publishDate, author } = post.data;

// Format the date nicely
const formattedDate = publishDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<html lang="en">
    <head> </head>
    <body>
        <RevealSlides theme={theme}>
            <!-- Title slide from frontmatter -->
            <section class="title-slide">
                <h1>{title}</h1>
                {description && <p>{description}</p>}
                {author && <p>{author}</p>}
                {
                    publishDate && (
                        <p>
                            <small>{formattedDate}</small>
                        </p>
                    )
                }
            </section>

            <!-- Slides content from markdown -->
            <slot />
        </RevealSlides>
    </body>
</html>
