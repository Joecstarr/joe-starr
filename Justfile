set export

@_default:
    just --list

# Set up development environment
bootstrap:
    if test ! -e node_modules; then \
      git submodule deinit -f . ; \
      git submodule update --init --recursive ; \
      prek install -f -c .pre-commit-config.yaml ; \
      npm install ; \
      npm run ; \
    fi

##################################################################################################
####### submodule ################################################################################
##################################################################################################

clean-submodule: 
      git submodule deinit -f . 
      git submodule update --init --recursive 

##################################################################################################
####### build ####################################################################################
##################################################################################################
    
# Run build 
build:
    npm run build 

##################################################################################################
####### dev ####################################################################################
##################################################################################################
    
# Run build 
dev:
    npm run dev 

##################################################################################################
####### build live ###############################################################################
##################################################################################################
    
# Run preview 
preview: build
    live-server  ./dist -p 1313 


##################################################################################################
####### rumdl format ##########################################################################
##################################################################################################
    
# Run rumdl 
do-rumdl:
    rumdl fmt --fix --include "**/*.md,**/*.mdx" .

##################################################################################################
####### tombi format ##########################################################################
##################################################################################################
    
# Run tombi 
do-tombi:
    tombi format . 
    
##################################################################################################
####### prettier format ##########################################################################
##################################################################################################
    
# Run prettier 
do-prettier:
    prettier --no-error-on-unmatched-pattern --write "**/*.astro"
    prettier --no-error-on-unmatched-pattern --write "**/*.ts"
    prettier --no-error-on-unmatched-pattern --write "**/*.tsx"
    prettier --no-error-on-unmatched-pattern --write "**/*.jsx"
    prettier --no-error-on-unmatched-pattern --write "**/*.js"
    prettier --no-error-on-unmatched-pattern --write "**/*.css"

##################################################################################################
####### check everything #########################################################################
##################################################################################################

# Check all style and formatting. Fail on warning.  
check: 
    prek run --all-files
    @echo "🚀 Checked the files"
    exit 0

##################################################################################################
####### all format ###############################################################################
##################################################################################################

# Run all formatting.  
format: do-prettier do-rumdl do-tombi 
    @echo "🚀 Formated the files"
    exit 0