---
/**
 * RevealSlides - A simple wrapper component for Reveal.js presentations
 *
 * This component provides the HTML structure for Reveal.js slides.
 * The initialization script is in the Slides layout.
 *
 * Dependencies: Reveal.js loaded from CDN
 */

interface Props {
    theme?:
        | "black"
        | "dracula"
        | "white"
        | "league"
        | "beige"
        | "sky"
        | "night"
        | "serif"
        | "simple"
        | "solarized"
        | "blood"
        | "moon";
}

const { theme = "black" } = Astro.props;
---

<!-- Reveal.js CSS from CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/dist/reveal.css" />
<link
    rel="stylesheet"
    href={`https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/dist/theme/${theme}.css`}
/>
<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/plugin/highlight/monokai.css"
/>

<!-- Reveal.js container - the slot will contain your markdown-generated slides -->
<div class="reveal">
    <div class="slides">
        <slot />
    </div>
</div>

<style is:global>
    /* Ensure the presentation takes full viewport */
    html,
    body {
        height: 100%;
        overflow: hidden;
        margin: 0;
        padding: 0;
    }

    /* Fix for markdown content in slides */
    .reveal .slides section {
        text-align: left;
    }

    .reveal .slides section > h1,
    .reveal .slides section > h2 {
        text-align: center;
    }

    /* Better code block styling */
    .reveal pre code {
        max-height: 500px;
    }

    /* Center content on title slide */
    .reveal .title-slide {
        text-align: center !important;
    }

    .reveal .title-slide h1,
    .reveal .title-slide p {
        text-align: center !important;
    }
</style>

<script type="module">
    // Load Reveal.js from CDN
    import Reveal from "https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/dist/reveal.esm.js";
    import Markdown from "https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/plugin/markdown/markdown.esm.js";
    import Highlight from "https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/plugin/highlight/highlight.esm.js";
    import Notes from "https://cdn.jsdelivr.net/npm/reveal.js@5.2.1/plugin/notes/notes.esm.js";

    // Initialize Reveal.js
    Reveal.initialize({
        // Display options
        controls: true,
        progress: true,
        center: true,
        hash: true,

        // Transition style
        transition: "slide", // none/fade/slide/convex/concave/zoom

        // Plugins
        plugins: [Markdown, Highlight, Notes],
    });
</script>
